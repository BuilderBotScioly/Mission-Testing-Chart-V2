<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Mission Possible Practice Scorer</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <main class="container">
    <h1>Mission Possible Practice Scorer</h1>

    <!-- LOGIN -->
    <section id="loginSection" class="card">
      <h2>Login</h2>
      <p class="muted">GitHub Pages version: runs save on this device. Login is a lock screen.</p>

      <label>Username</label>
      <input id="username" placeholder="Enter username" autocomplete="username" />

      <label>Password</label>
      <input id="password" type="password" placeholder="Enter password" autocomplete="current-password" />

      <div class="row">
        <button id="loginBtn">Log in</button>
        <button id="setCredsBtn" class="secondary">Set/Change Login</button>
      </div>

      <p id="loginMsg" class="msg"></p>
    </section>

    <!-- APP -->
    <section id="appSection" class="card hidden">
      <div class="row space-between">
        <h2>Add Run</h2>
        <div class="row">
          <button id="exportBtn" class="secondary">Export CSV</button>
          <button id="logoutBtn" class="secondary">Log out</button>
        </div>
      </div>

      <div class="grid">
        <div>
          <label>Date/Time</label>
          <input id="occurredAt" type="datetime-local" />
        </div>
        <div>
          <label>Notes</label>
          <input id="notes" placeholder="optional" />
        </div>
      </div>

      <h3>Rule Scoring</h3>

      <div class="grid">
        <div>
          <label>Setup done in ≤ 30 minutes? (50 pts)</label>
          <select id="setup30">
            <option value="no">No</option>
            <option value="yes">Yes</option>
          </select>
        </div>

        <div>
          <label>ASL: 2 printed copies presented? (25 pts)</label>
          <select id="aslCopies">
            <option value="no">No</option>
            <option value="yes">Yes</option>
          </select>
        </div>

        <div>
          <label>ASL: proper format? (25 pts)</label>
          <select id="aslFormat">
            <option value="no">No</option>
            <option value="yes">Yes</option>
          </select>
        </div>

        <div>
          <label>ASL: all actions included & accurate? (25 pts)</label>
          <select id="aslAccurate">
            <option value="no">No</option>
            <option value="yes">Yes</option>
          </select>
        </div>

        <div class="full">
          <label>ASL: labels & roman numerals correct? (25 pts)</label>
          <select id="aslLabels">
            <option value="no">No</option>
            <option value="yes">Yes</option>
          </select>
        </div>

        <div>
          <label>Start Action completed? (100 pts)</label>
          <select id="startAction">
            <option value="no">No</option>
            <option value="yes">Yes</option>
          </select>
        </div>

        <div>
          <label>Bell rung at end? (100 pts)</label>
          <select id="bell">
            <option value="no">No</option>
            <option value="yes">Yes</option>
          </select>
        </div>

        <div>
          <label>No adjustments during operation? (75 pts)</label>
          <select id="noAdjustments">
            <option value="no">No</option>
            <option value="yes">Yes</option>
          </select>
        </div>
      </div>

      <h3>12 Scorable Actions (50 pts each)</h3>
      <p class="muted">Select Yes for each action you successfully completed.</p>
      <div id="actionsWrap" class="grid"></div>

      <div class="grid">
        <div>
          <label>Total Score (computed)</label>
          <input id="totalScore" type="number" readonly />
        </div>
      </div>

      <button id="addRunBtn">Save Run</button>
      <p id="appMsg" class="msg"></p>

      <h3>History</h3>
      <div class="tableWrap">
        <table id="runsTable">
          <thead>
            <tr>
              <th>Date</th>
              <th>Total</th>
              <th>Notes</th>
              <th></th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </section>
  </main>

  <script src="app.js"></script>
</body>
</html>
